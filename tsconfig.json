{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./app/src",
    "skipLibCheck": true
  },
  "include": ["app/src/**/*"],
  "exclude": ["node_modules"]
}
